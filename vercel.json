{
  "git": {
    "deploymentEnabled": {
      "claude/*": false
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-reconcile",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/data-pruning",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/credit-allocation",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/setup/run-enrichment",
      "schedule": "* * * * *"
    }
  ]
}
