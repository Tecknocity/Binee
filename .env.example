# Encryption (for storing OAuth tokens)
TOKEN_ENCRYPTION_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SETUP_PRICE_ID=
STRIPE_PRICE_MO_50=
STRIPE_PRICE_MO_100=
STRIPE_PRICE_MO_250=
STRIPE_PRICE_MO_500=
STRIPE_PRICE_MO_1000=
STRIPE_PRICE_YR_50=
STRIPE_PRICE_YR_100=
STRIPE_PRICE_YR_250=
STRIPE_PRICE_YR_500=
STRIPE_PRICE_YR_1000=

# Vercel Cron protection
CRON_SECRET=

# App URL
# Local: http://localhost:3000
# Production: https://app.binee.io
NEXT_PUBLIC_APP_URL=http://localhost:3000
