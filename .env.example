# Copy this to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# ClickUp
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
CLICKUP_REDIRECT_URI=http://localhost:3000/api/clickup/callback

# Encryption (for storing OAuth tokens)
TOKEN_ENCRYPTION_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SETUP_PRICE_ID=
STRIPE_PRICE_MO_100=
STRIPE_PRICE_MO_150=
STRIPE_PRICE_MO_250=
STRIPE_PRICE_MO_500=
STRIPE_PRICE_MO_750=
STRIPE_PRICE_MO_1000=
STRIPE_PRICE_MO_2000=
STRIPE_PRICE_YR_100=
STRIPE_PRICE_YR_150=
STRIPE_PRICE_YR_250=
STRIPE_PRICE_YR_500=
STRIPE_PRICE_YR_750=
STRIPE_PRICE_YR_1000=
STRIPE_PRICE_YR_2000=
STRIPE_PRICE_PAYG_100=
STRIPE_PRICE_PAYG_150=
STRIPE_PRICE_PAYG_250=
STRIPE_PRICE_PAYG_500=
STRIPE_PRICE_PAYG_750=
STRIPE_PRICE_PAYG_1000=
STRIPE_PRICE_PAYG_2000=

# Vercel Cron protection
CRON_SECRET=

# App URL
# Local: http://localhost:3000
# Production: https://app.binee.io
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Setup chat architecture
# - ON by default (multi-agent: Haiku Clarifier + Sonnet Generator/Reviser).
# - Set to "false" only as an emergency rollback to the legacy single-Sonnet
#   handler. Any other value (or unset) keeps multi-agent on.
# MULTI_AGENT_SETUP=false

# Setup chat intent classifier (Phase 0 rollout of adaptive routing).
# Default 'disabled' is bit-identical to current production. Valid values:
#   - disabled (default): classifier never runs, no behavior change
#   - shadow:             classifier runs and logs decisions, no routing change
#   - info_only:          'info' classifications activate the new Info Handler;
#                         discovery and refine still use legacy isReadyDraft routing
#   - enabled:            full classifier-driven routing
# Anything else is treated as 'disabled'. See src/lib/setup/setupper-brain.ts
# for the orchestration and src/lib/setup/intent-classifier.ts for the prompt.
# SETUP_INTENT_CLASSIFIER=disabled
